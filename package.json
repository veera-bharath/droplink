{
  "name": "droplink",
  "version": "1.0.0",
  "description": "A polished production-ready local file transfer web application",
  "main": "main.js",
  "bin": "dist/server/index.js",
  "scripts": {
    "dev": "npm run server:build && electron .",
    "start": "npm run server:build && electron .",
    "build": "tsc && electron-builder --win",
    "server:dev": "ts-node-dev --respawn --transpile-only server/index.ts",
    "server:build": "rimraf dist && tsc",
    "server:start": "node dist/server/index.js"
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ]
  },
  "build": {
    "appId": "com.droplink.app",
    "productName": "DropLink",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "assets/**/*",
      "dist/**/*",
      "public/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DropLink",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "include": "installer/context-menu.nsh"
    },
    "publish": {
      "provider": "github",
      "owner": "veera-bharath",
      "repo": "droplink"
    }
  },
  "keywords": [
    "file-transfer",
    "local-network",
    "wifi-share",
    "developer-tool"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.5.10",
    "electron": "^30.0.9",
    "electron-builder": "^24.13.3",
    "pkg": "^5.8.1",
    "rimraf": "^5.0.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
